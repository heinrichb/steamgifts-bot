#!/bin/sh
# Pre-commit hook: runs formatters and fails if anything is unformatted.
# Install with: git config core.hooksPath .githooks

set -e

echo "pre-commit: checking Go formatting..."
bad=$(gofmt -l . 2>&1)
if [ -n "$bad" ]; then
  echo "gofmt: these files need formatting:"
  echo "$bad"
  echo "Run 'make fmt' to fix."
  exit 1
fi

echo "pre-commit: checking Prettier (YAML/MD/JSON)..."
if command -v npx >/dev/null 2>&1; then
  npx --yes prettier --check '**/*.{yml,md,json}' --ignore-path .prettierignore || {
    echo "Run 'make fmt' to fix."
    exit 1
  }
fi

echo "pre-commit: all checks passed."
